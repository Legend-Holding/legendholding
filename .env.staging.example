# Copy this file to `.env.staging` and set staging-safe values.
# Do not commit `.env.staging`.

APP_ENV=staging
NEXT_PUBLIC_APP_ENV=staging

# Public app URL for staging
NEXT_PUBLIC_APP_URL=https://staging.legendholding.com

# Postgres (staging) — direct connection (no Supabase)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
# Wrap password in double quotes if it contains special characters ($, !, #, &, etc.)
POSTGRES_PASSWORD=""
POSTGRES_SSL=false
ADMIN_SESSION_SECRET=
# Optional: override pool size (default 10)
# POSTGRES_MAX_CONNECTIONS=10

# Email provider (staging)
RESEND_API_KEY=

# Cloudinary (staging)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
